@typeparam TEntity

@inherits WidgetComponentBase<PluginEntry>
@switch (_stage)
{
    case Stage.Confirm:
        <MudIconButton Icon="@Icons.Material.Filled.AutoDelete" Color=Color.Warning OnClick=Confirm Disabled=Disabled />
        break;
    case Stage.Cancel:
        <MudIconButton Icon="@Icons.Material.Filled.RestoreFromTrash" Color=Color.Primary OnClick=Cancel Disabled=Disabled />
        break;
    default:
        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color=Color.Error OnClick=InitialClick Disabled=Disabled />
        break;
}

