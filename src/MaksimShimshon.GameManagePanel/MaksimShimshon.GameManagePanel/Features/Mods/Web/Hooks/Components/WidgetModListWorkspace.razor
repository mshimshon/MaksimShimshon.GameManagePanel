@using MaksimShimshon.GameManagePanel.Features.Mods.Web.Components
@using MaksimShimshon.GameManagePanel.Features.Mods.Web.Hooks.Components.ViewModels
@inherits WidgetComponentBase<PluginEntry, IWidgetModListWorkspaceViewModel>

<MudGrid>
    <MudItem xs=12>
        @if (ViewModel.ModListLocalState.Current == default && ModListId == Guid.Empty)
        {
            <ModListExplorer OnParentStateHasChanged=OnParentStateHasChanged />
        }
        else
        {
            <ModListEditor id=@ViewModel.GetModListId() OnParentStateHasChanged=OnParentStateHasChanged />
        }

    </MudItem>
</MudGrid>