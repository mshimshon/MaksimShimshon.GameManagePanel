@using MaksimShimshon.GameManagePanel.Features.Mods.Web.Components
@using MaksimShimshon.GameManagePanel.Features.Mods.Web.Hooks.Components.ViewModels
@inherits WidgetComponentBase<PluginEntry, IWidgetModlistSelectorViewModel>

@if(ViewModel.ModsListState.Available.Count() > 0)
{
    <MudGrid>
        <MudItem xs=12 sm=12 md=4>
            <MudPaper Class="justify-space-around mud-width-full py-6 px-6">
                <ModListSelector OnParentStateHasChanged=@InvokeParentStateChanged />
            </MudPaper>
        </MudItem>
    </MudGrid>
}

